# Copy to .env.development or .env.production and adjust.

# Browser → API (see src/services/api.js)
# Dev: use /api so Vite proxies to XAMPP (session cookies stay on localhost).
VITE_API_BASE=/api

# Vite dev server only: where /api/* is forwarded (Apache + ZemaLink folder).
# Prefer 127.0.0.1 on Windows — "localhost" can resolve to IPv6 while XAMPP is IPv4-only (502).
VITE_PROXY_TARGET=http://127.0.0.1/ZemaLink/backend
# If Apache uses another port: http://127.0.0.1:8080/ZemaLink/backend

# Where Apache serves uploads / cover images (not the /api proxy).
VITE_BACKEND_PUBLIC_URL=http://127.0.0.1/ZemaLink/backend

# Production example (same host as frontend, or full backend URL):
# VITE_API_BASE=https://your-site.com/ZemaLink/backend
